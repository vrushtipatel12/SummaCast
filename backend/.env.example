# Core Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration (Authentication)
JWT_SECRET=summacast_access_secret_key_2026
JWT_REFRESH_SECRET=summacast_refresh_secret_key_2026
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Database Configuration (supports 'sqlite' or 'postgres')
DB_TYPE=sqlite
# For Local SQLite:
SQLITE_DB_PATH=./database.sqlite
# For Production PostgreSQL (Railway):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/summacast

# Queue & Background Processing (Redis / BullMQ)
# If empty, the server automatically falls back to an in-memory job runner for local dev.
REDIS_URL=

# Media Storage Configuration
# If AWS keys are empty, the backend automatically uses direct local disk uploads into UPLOAD_DIR.
UPLOAD_DIR=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Python Worker API URL (for sending jobs in mock/local mode)
PYTHON_WORKER_URL=http://127.0.0.1:8000
